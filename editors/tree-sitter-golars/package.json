{
  "name": "tree-sitter-golars",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for golars .glr scripting language",
  "main": "bindings/node",
  "keywords": ["parser", "tree-sitter", "golars", "glr"],
  "license": "MIT",
  "dependencies": {
    "nan": "^2.20.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.0"
  },
  "scripts": {
    "build": "tree-sitter generate && tree-sitter build",
    "parse": "tree-sitter parse",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.golars",
      "file-types": ["glr"],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ]
}
